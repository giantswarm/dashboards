    {
      "id": 18,
      "type": "timeseries",
      "title": "Customer WC — Actual CPU vs Requested",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 55},
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Requested"},
            "properties": [
              {"id": "color", "value": {"fixedColor": "#FFC000", "mode": "fixed"}},
              {"id": "custom.fillOpacity", "value": 0}
            ]
          }
        ]
      },
      "options": {
        "legend": {"showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum(rate(container_cpu_usage_seconds_total{cluster_id=~\"$cluster\", cluster_type=\"workload_cluster\", namespace!=\"kube-system\", container!=\"\", container!=\"POD\"}[$__rate_interval]))",
          "instant": false,
          "range": true,
          "legendFormat": "Actual",
          "refId": "A"
        },
        {
          "datasource": "${datasource}",
          "expr": "sum(kube_pod_container_resource_requests{cluster_id=~\"$cluster\", cluster_type=\"workload_cluster\", namespace!=\"kube-system\", resource=\"cpu\"})",
          "instant": false,
          "range": true,
          "legendFormat": "Requested",
          "refId": "B"
        }
      ]
    },
