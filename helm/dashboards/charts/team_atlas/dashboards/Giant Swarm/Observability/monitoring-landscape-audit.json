  "templating": {
    "list": [
      {
        "label": "Data source",
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "sort": 2,
        "type": "datasource"
      },
      {
        "datasource": "${datasource}",
        "label": "Cluster",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "name": "cluster",
        "query": {
          "query": "label_values(kube_pod_info{}, cluster_id)",
          "refId": "cluster"
        },
        "refresh": 2,
        "sort": 2,
        "type": "query"
      }
    ]
  },
  "time": {
