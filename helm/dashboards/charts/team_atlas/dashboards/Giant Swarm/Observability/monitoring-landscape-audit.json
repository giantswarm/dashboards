      "id": 19,
      "type": "timeseries",
      "title": "Customer WC — Actual Memory vs Requested",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 55},
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
