  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {"h": 3, "w": 24, "x": 0, "y": 0},
      "options": {
        "content": "Audits monitoring and observability tools deployed across clusters, showing CPU and memory resource consumption. Enables comparison between the current monitoring landscape and the GiantSwarm observability platform to support consolidation conversations.\n\n**GiantSwarm components:** management cluster (all namespaces) · workload cluster `kube-system`  \n**Customer components:** workload cluster namespaces outside `kube-system`",
        "mode": "markdown"
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "Overview",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 3},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 3,
      "type": "stat",
      "title": "GiantSwarm Platform — CPU Requests",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 4},
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "color": {"mode": "fixed", "fixedColor": "blue"}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum(\n  kube_pod_container_resource_requests{cluster_id=~\"$cluster\", resource=\"cpu\", cluster_type=\"management_cluster\"}\n  or\n  kube_pod_container_resource_requests{cluster_id=~\"$cluster\", resource=\"cpu\", cluster_type=\"workload_cluster\", namespace=\"kube-system\"}\n)",
          "instant": true,
          "legendFormat": "GiantSwarm CPU",
          "refId": "A"
        }
      ]
    },
