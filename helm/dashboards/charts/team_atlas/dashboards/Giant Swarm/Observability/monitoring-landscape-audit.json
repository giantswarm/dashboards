    {
      "id": 16,
      "type": "table",
      "title": "Customer Workload Clusters — All Pods Outside kube-system",
      "description": "Complete inventory of pods in customer-controlled namespaces. Use this to identify monitoring tools not captured by automated detection. Sorted by CPU requests descending.",
      "gridPos": {"h": 15, "w": 24, "x": 0, "y": 39},
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value #A"},
            "properties": [
              {"id": "displayName", "value": "CPU requests (cores)"},
              {"id": "unit", "value": "short"},
              {"id": "custom.width", "value": 160}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Value #B"},
            "properties": [
              {"id": "displayName", "value": "Memory requests"},
              {"id": "unit", "value": "bytes"},
              {"id": "custom.width", "value": 160}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Time"},
            "properties": [{"id": "custom.hidden", "value": true}]
          }
        ]
      },
      "options": {
        "sortBy": [{"displayName": "CPU requests (cores)", "desc": true}],
        "footer": {"show": false}
      },
      "transformations": [
        {"id": "merge", "options": {}},
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true},
            "indexByName": {
              "cluster_id": 0,
              "namespace": 1,
              "pod": 2,
              "container": 3,
              "Value #A": 4,
              "Value #B": 5
            },
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (cluster_id, namespace, pod, container) (\n  kube_pod_container_resource_requests{\n    cluster_id=~\"$cluster\",\n    cluster_type=\"workload_cluster\",\n    namespace!=\"kube-system\",\n    resource=\"cpu\"\n  }\n)",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": "${datasource}",
          "expr": "sum by (cluster_id, namespace, pod, container) (\n  kube_pod_container_resource_requests{\n    cluster_id=~\"$cluster\",\n    cluster_type=\"workload_cluster\",\n    namespace!=\"kube-system\",\n    resource=\"memory\"\n  }\n)",
          "instant": true,
          "format": "table",
          "legendFormat": "",
          "refId": "B"
        }
      ]
    },
