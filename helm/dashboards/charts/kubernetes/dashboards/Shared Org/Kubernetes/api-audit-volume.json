                      },
                      "group": "prometheus",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "9 * 1024 * 1024 * 1024 / (sum by(cluster_id) (rate(k8s_api_audit_requests_total{organization=~\"$organization\",cluster_id=~\"$cluster_id\",cluster_id=~\"$cluster_id\"}[$__rate_interval])) * 86400 * 1600)",
                        "format": "table",
                        "instant": true,
                        "legendFormat": "__auto",
                        "range": false
                      },
                      "version": "v0"
                    },
                    "refId": "retention_days"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": [
                {
                  "group": "joinByField",
                  "kind": "Transformation",
                  "spec": {
                    "options": {
                      "byField": "cluster_id",
                      "mode": "outer"
                    }
                  }
                },
                {
                  "group": "organize",
                  "kind": "Transformation",
                  "spec": {
                    "options": {
                      "excludeByName": {
                        "Time 1": true,
                        "Time 2": true,
                        "Time 3": true,
                        "Time 4": true
                      },
                      "indexByName": {
                        "cluster_id": 0,
                        "Value #events_per_sec": 1,
                        "Value #events_per_day": 2,
                        "Value #bytes_per_day": 3,
                        "Value #retention_days": 4
                      },
                      "renameByName": {
                        "cluster_id": "Cluster",
                        "Value #events_per_sec": "events/sec",
                        "Value #events_per_day": "events/day",
                        "Value #bytes_per_day": "bytes/day",
                        "Value #retention_days": "retention_days"
                      }
                    }
                  }
                }
              ]
            }
